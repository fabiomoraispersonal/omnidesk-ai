{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Authorization": {
    "ImpersonationJwtTtlSeconds": 300
  },
  "Ai": {
    "MaxSuggestionContextMessages": 20,
    "DefaultModel": "gpt-4o",
    "RunTimeoutSeconds": 30,
    "RunMaxRetries": 1,
    "RunRetryBackoffSeconds": 3,
    "PlaygroundTtlSeconds": 1800,
    "GlobalAllowedModels": [ "gpt-4o", "gpt-4o-mini", "gpt-4-turbo" ]
  }
}
