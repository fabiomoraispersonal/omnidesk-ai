{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=omnidesk;Username=postgres;Password=postgres"
  },
  "Redis": {
    "Url": "redis://localhost:6379"
  },
  "Mongo": {
    "Url": "mongodb://localhost:27017"
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:4200,http://localhost:4201"
  },
  "Frontend": {
    "CrmBaseUrl": "http://localhost:4201"
  },
  "Authorization": {
    "ImpersonationJwtTtlSeconds": 300
  },
  "Ai": {
    "MaxSuggestionContextMessages": 20,
    "DefaultModel": "gpt-4o",
    "RunTimeoutSeconds": 30,
    "RunMaxRetries": 1,
    "RunRetryBackoffSeconds": 3,
    "PlaygroundTtlSeconds": 1800,
    "GlobalAllowedModels": [ "gpt-4o", "gpt-4o-mini", "gpt-4-turbo" ]
  },
  "Widget": {
    "ResumedContextMessageLimit": 50,
    "MaxUploadBytes": 10485760,
    "CdnBaseUrl": "https://cdn.omnicare.ia.br/widget/v1",
    "PublicRateLimitPerMinute": 30
  },
  "WhatsApp": {
    "GraphApiBaseUrl": "https://graph.facebook.com/v19.0",
    "WebhookProcessingTimeoutSeconds": 5,
    "SessionWindowHours": 24,
    "SessionExpiringThresholdMinutes": 60
  },
  "Tickets": {
    "SlaWarningThresholdPercent": 80,
    "KanbanRefreshSeconds": 30
  },
  "Push": {
    "VapidSubject": "",
    "VapidPublicKey": "",
    "VapidPrivateKey": ""
  },
  "Notifications": {
    "ArchiveRetentionDays": 90,
    "QueueAlertThresholdMinutes": 5,
    "PushSendTimeoutMs": 3000
  }
}
