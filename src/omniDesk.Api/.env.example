# OmniDesk API — environment variables (example)

# JWT (RSA, PEM format)
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=

# Database
ConnectionStrings__Default=Host=localhost;Port=5432;Database=omnidesk;Username=postgres;Password=postgres

# Redis
REDIS_URL=redis://localhost:6379

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201

# Frontend CRM base URL (used by impersonation redirect)
FRONTEND_CRM_BASE_URL=http://localhost:4201

# Authorization (Spec 004 — Roles e Permissões)
# TTL for impersonation JWT in seconds. Default 300 (5 min). Maximum allowed 600 (10 min) — startup fails if exceeded.
IMPERSONATION_JWT_TTL_SECONDS=300
