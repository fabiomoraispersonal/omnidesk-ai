# OmniDesk API — environment variables (example)

# JWT (RSA, PEM format)
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=

# Database
ConnectionStrings__Default=Host=localhost;Port=5432;Database=omnidesk;Username=postgres;Password=postgres

# Redis
REDIS_URL=redis://localhost:6379

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201

# Frontend CRM base URL (used by impersonation redirect)
FRONTEND_CRM_BASE_URL=http://localhost:4201

# Authorization (Spec 004 — Roles e Permissões)
# TTL for impersonation JWT in seconds. Default 300 (5 min). Maximum allowed 600 (10 min) — startup fails if exceeded.
IMPERSONATION_JWT_TTL_SECONDS=300

# AI suggestion (Spec 005 — Departamentos e Atendentes)
# Number of recent conversation messages fed to OpenAI when generating a suggested reply.
# Default 20, maximum 50 (cap enforced by SuggestReplyService).
MAX_SUGGESTION_CONTEXT_MESSAGES=20

# OpenAI key (Spec 002 — Agentes IA; consumed by Spec 005 sugestão de resposta + Spec 006 orchestrator)
OPENAI_API_KEY=

# AI agents runtime (Spec 006 — Agentes de IA)
# Default model used when tenant didn't pick one. Constituição V — gpt-4o.
Ai__DefaultModel=gpt-4o
# Run polling timeout. Above this is treated as 5xx (FR-018).
Ai__RunTimeoutSeconds=30
# Retry policy: 1 retry then transbordo. Constituição V — sem Polly.
Ai__RunMaxRetries=1
Ai__RunRetryBackoffSeconds=3
# TTL of the playground thread session in Redis (FR-026/027).
Ai__PlaygroundTtlSeconds=1800
# Comma-separated allowlist of OpenAI models tenants may pick from.
Ai__GlobalAllowedModels=gpt-4o,gpt-4o-mini,gpt-4-turbo

# MongoDB (Spec 003 — provisioned per tenant; Spec 005 logs status + ai_suggestion telemetry)
MONGODB_URL=mongodb://localhost:27017
