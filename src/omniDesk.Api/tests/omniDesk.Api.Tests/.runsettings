<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <!-- Default test filter — excludes live OpenAI smoke tests from CI runs.
         To run live smoke locally: dotnet test --filter "openai-live=true"
         (requires OPENAI_API_KEY env var with billing-enabled key).
         ADR-006-001 explains why these are gated. -->
    <TestSessionTimeout>600000</TestSessionTimeout>
    <TreatNoTestsAsError>false</TreatNoTestsAsError>
  </RunConfiguration>

  <MSTest>
    <Parallelize>
      <Workers>1</Workers>
      <Scope>ClassLevel</Scope>
    </Parallelize>
  </MSTest>

  <!-- xUnit + Testcontainers — TenantSchemaFixture provisions Postgres+Redis+Mongo
       once per collection; tests share the boot. Default filter excludes openai-live. -->
  <RunConfiguration>
    <TestCaseFilter>openai-live!=true</TestCaseFilter>
  </RunConfiguration>
</RunSettings>
